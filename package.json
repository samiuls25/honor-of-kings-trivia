{
  "name": "hok-trivia",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "ingest:extract": "node scripts/ingest/from-capture.mjs",
    "ingest:validate": "node scripts/ingest/validate-skins.mjs",
    "ingest:generate": "node scripts/ingest/generate-ts.mjs",
    "ingest:all": "npm run ingest:extract && npm run ingest:validate && npm run ingest:generate",
    "ingest:qing:extract": "node scripts/ingest/from-qing-api.mjs",
    "ingest:qing:translate": "node scripts/ingest/translate-qing-to-english.mjs",
    "ingest:qing:validate": "node scripts/ingest/validate-skins.mjs data/processed/skins.qing.en.normalized.json",
    "ingest:qing:quality": "node scripts/ingest/report-skins-quality.mjs data/processed/skins.qing.en.normalized.json",
    "ingest:qing:generate": "node scripts/ingest/generate-ts.mjs data/processed/skins.qing.en.normalized.json data/processed/meta.qing.json src/data/skins.qing.generated.ts",
    "ingest:qing:all": "npm run ingest:qing:extract && npm run ingest:qing:translate && npm run ingest:qing:validate && npm run ingest:qing:quality && npm run ingest:qing:generate",
    "ingest:ost:fetch": "node scripts/ingest/fetch-youtube-ost.mjs",
    "ingest:ost:extract": "node scripts/ingest/from-ost-source.mjs",
    "ingest:ost:validate": "node scripts/ingest/validate-ost.mjs",
    "ingest:ost:generate": "node scripts/ingest/generate-ost-ts.mjs",
    "ingest:ost:all": "npm run ingest:ost:fetch && npm run ingest:ost:extract && npm run ingest:ost:validate && npm run ingest:ost:generate",
    "ingest:hero-identity:extract": "node scripts/ingest/from-hero-identity.mjs",
    "ingest:hero-identity:validate": "node scripts/ingest/validate-hero-identity.mjs",
    "ingest:hero-identity:generate": "node scripts/ingest/generate-hero-identity-ts.mjs",
    "ingest:hero-identity:all": "npm run ingest:hero-identity:extract && npm run ingest:hero-identity:validate && npm run ingest:hero-identity:generate",
    "ingest:hero-relationships:extract": "node scripts/ingest/from-hero-relationships.mjs",
    "ingest:hero-relationships:validate": "node scripts/ingest/validate-hero-relationships.mjs",
    "ingest:hero-relationships:generate": "node scripts/ingest/generate-hero-relationships-ts.mjs",
    "ingest:hero-relationships:all": "npm run ingest:hero-relationships:extract && npm run ingest:hero-relationships:validate && npm run ingest:hero-relationships:generate"
  },
  "dependencies": {
    "@netlify/blobs": "^10.0.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  }
}
